# Copy to .env (git-ignored) or export these in your shell / MCP config.
# The session cookie is the ONLY secret. It must contain auth_token + ct0.

# Option 1 — full cookie string inline (mind your shell history)
# TWEETKIT_COOKIE="auth_token=...; ct0=...; twid=u%3D123...; guest_id=..."

# Option 2 — a file holding the cookie string
# TWEETKIT_COOKIE_FILE="/Users/you/.config/tweetkit/cookie.txt"

# Option 3 — macOS Keychain slug (store with `tweetkit import ... --keychain tweetkit`)
# TWEETKIT_COOKIE_KEYCHAIN="tweetkit"
